<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CoolWeatherApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <item name="background">@color/background_blue</item>
        <item name="android:textColor">@color/default_text_color</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Theme.Day" parent="Theme.CoolWeatherApp">
        <item name="mainBackgroundImage">@drawable/background_portrait_day</item>
        <item name="background">@color/background_blue_day</item>
    </style>

    <style name="Theme.Day.Land" parent="Theme.CoolWeatherApp">
        <item name="mainBackgroundImage">@drawable/background_landscape_day</item>
    </style>

    <style name="Theme.Night" parent="Theme.CoolWeatherApp">
        <item name="mainBackgroundImage">@drawable/background_portrait_night</item>
    </style>

    <style name="Theme.Night.Land" parent="Theme.CoolWeatherApp">
        <item name="android:textColor">@color/night_land_color</item>
        <item name="mainBackgroundImage">@drawable/background_landscape_night</item>
    </style>
</resources>